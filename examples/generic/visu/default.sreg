# default experiment file that is loaded when the gui starts up

- Name: RunSystem

  DoublePendulum:

  Trajectory:
    Type: 1
    times: [0, 1]
    values: [0, 0.15]

  Visu:
    MplDoublePendulumVisualizer:

  Config:
    TimerTime: 10
    InterpolationPoints: 0
    MovingWindowSize: 10
    MovingWindowEnable: True
    HeartbeatTime: 0
